gtag('js',new Date());gtag('config','G-QCLYFZQNYJ')</script><link rel="icon" href="https://www.tourist-in-rom.com/wp-content/uploads/2017/09/Piccolo_website_icon.jpg" sizes="32x32" /><link rel="icon" href="https://www.tourist-in-rom.com/wp-content/uploads/2017/09/Piccolo_website_icon.jpg" sizes="192x192" /><link rel="apple-touch-icon" href="https://www.tourist-in-rom.com/wp-content/uploads/2017/09/Piccolo_website_icon.jpg" /><meta name="msapplication-TileImage" content="https://www.tourist-in-rom.com/wp-content/uploads/2017/09/Piccolo_website_icon.jpg" /><style id="wp-custom-css">/* Query title language selection */
html:lang(de-DE)  :is(.query-title-en , .query-title-it) {
    display: none;
}
html:lang(en-US)  :is(.query-title-de , .query-title-it) {
    display: none;
}
html:lang(it-IT)  :is(.query-title-de , .query-title-en) {
    display: none;
}
/* Navigation */
@media (max-width: 768px) {
  nav#secondary-navigation {
    display: none;
  }
}

@media (max-width: 768px) {
    .main-navigation .main-nav ul li a {
        border-bottom: rgba(349, 81, 57, 0.5) 1px solid;
			border-right: rgba(255, 255, 255, 0.5) 1px solid;
    }
}
body .slideout-overlay {
    background-color: rgba(0,0,0,.2);
}
.site-logo.mobile-header-logo img {
    padding: 5px 0;
}

/*3rd level menu indent*/
@media (min-width: 769px) {
.dropdown-click .main-navigation ul ul ul.toggled-on, .dropdown-click .main-navigation ul ul li.sfHover > ul.toggled-on {
    padding-left: 14px;
}
/*Search icon poaition on desktop*/
nav.main-navigation .inside-navigation {
    flex-wrap: nowrap;
}
}
/* Substitute for style.min.css*/
.wp-block-embed {
    margin: 0 0 1em;
    overflow-wrap: break-word
}

.wp-block-embed__wrapper {
    position: relative
}

.wp-block-image {
    margin: 0 0 1em
}

.wp-block-image img {
    height: auto;
    max-width: 100%;
    vertical-align: bottom
}

.wp-block-image:not(.is-style-rounded)>a,.wp-block-image:not(.is-style-rounded) img {
    border-radius: inherit
}

.wp-block-image.aligncenter {
    text-align: center
}

.wp-block-image.alignfull img,.wp-block-image.alignwide img {
    height: auto;
    width: 100%
}

.wp-block-image.aligncenter,.wp-block-image .aligncenter,.wp-block-image.alignleft,.wp-block-image .alignleft,.wp-block-image.alignright,.wp-block-image .alignright {
    display: table
}

.wp-block-image.aligncenter>figcaption,.wp-block-image .aligncenter>figcaption,.wp-block-image.alignleft>figcaption,.wp-block-image .alignleft>figcaption,.wp-block-image.alignright>figcaption,.wp-block-image .alignright>figcaption {
    display: table-caption;
    caption-side: bottom
}

.wp-block-image .alignleft {
    float: left;
    margin: .5em 1em .5em 0
}

.wp-block-image .alignright {
    float: right;
    margin: .5em 0 .5em 1em
}

.wp-block-image .aligncenter {
    margin-left: auto;
    margin-right: auto
}

.wp-block-image figcaption {
    margin-top: .5em;
    margin-bottom: 1em
}

.wp-block-image figure {
    margin: 0
}

ol,ul {
    box-sizing: border-box
}

.wp-block-spacer {
    clear: both
}

.wp-block-table {
    margin: 0 0 1em;
    overflow-x: auto
}

.wp-block-table table {
    border-collapse: collapse;
    width: 100%
}

.aligncenter {
    clear: both
}

:root {
    --wp--preset--font-size--normal: 16px;
    --wp--preset--font-size--huge: 42px
}

.screen-reader-text {
    border: 0;
    clip: rect(1px,1px,1px,1px);
    -webkit-clip-path: inset(50%);
    clip-path: inset(50%);
    height: 1px;
    margin: -1px;
    overflow: hidden;
    padding: 0;
    position: absolute;
    width: 1px;
    word-wrap: normal!important
}

html :where(img[class*=wp-image-]) {
    height: auto;
    max-width: 100%
}

/* Make last sidebar widget sticky*/
@media (min-width: 769px) {
 .site-content {
 display: flex;
 }
.inside-right-sidebar {
 height: 100%;
 }
.inside-right-sidebar aside:last-child {
 position: -webkit-sticky;
 position: sticky;
 top: 50px;
 }
 }

/* Formatierungen*/
blockquote {
      font-size: 17px;
}

/* Listen indent und Abstand unten*/
.entry-content ul {
    margin-left: 20px;
}
.entry-content ul li {
    margin-bottom: 0.5em;
}
.entry-content ul.simpletoc-list li {
    margin-bottom: 0.2em;
}

a.read-more.button {
    border-radius: 10px;
	padding: 5px 10px;
}
/* Accordion item height */
.gb-container.gb-accordion__item-open > .gb-accordion__content {
    max-height: inherit !important;
}

/* Line break before title */
h1,
h2,
h3,
h4 {
	clear: both}

/* smartslider lightbox background */
.litebox-overlay{
    background-color: rgba(147, 27, 49, 0.2)!important;
}

/*Formatierung Titel Homepage*/
nh1 {
  font-size: 24px;
  font-weight: bold;
  line-height: 1.2em;
  margin-bottom: 1px;
  color: #931b31;
}

/* Externer Link mit verschiedener Farbe */
p a:not([href*="tourist-in-rom"]) {
  color: #0026FF;
}

/* Kategorieseiten Titel */
.archive.category .page-header h1.page-title {
	margin-top: 10px;
    font-size: 17px;
    color: #fff;
    background: #931b31;
}

/* Formatierungen */
.border931 {
border: 1px solid #931b31;
border-radius: 5px;
}

.tocborder {
border: 1px solid #931b31;
padding: 10px;
}

.bordertop931 {
border-top: 1px solid #931b31;
}

.borderbottom931 {
border-bottom: 1px solid #931b31;
}

@media(min-width: 769px) {
	.borderright931 {
	border-right: 1px solid #931b31;
	}
}

.borderffc {
border: 1px solid #ffc231;
border-radius: 5px;
}

@media(min-width: 769px) {
	.borderrightffc {
	border-right: 1px solid #ffc231;
	}
}

.border01 {
border: 1px solid #000000;
}

.border02 {
border: 2px solid #000000;
}

.boxshadow1 {
-webkit-box-shadow: 0 0 8px 1px #606060; 
box-shadow: 0px 0px 8px 1px #606060;
}

.backgroundffc {
  background: rgba(251,245,231)
}

.background931 {
  background: rgba(244,232,234)
}

.grow { 
transition: all .2s ease-in-out; 
}

.grow:hover { 
transform: scale(1.1); 
}

.bold1 {
  font-weight: bold;
}
@media (min-width: 769px) {
.cu-float-right {
    float: right;
}
}
/* Center all Gutenberg images on mobile */
@media(max-width: 768px) {
    .wp-block-image .alignleft,
    .wp-block-image .alignright {
        float: none;
        margin-left: auto;
        margin-right: auto;
    }
}

/* GB Buttons transition deaktivieren ´wg.Pagespeed */
.gb-button-wrapper .gb-button {
    transition: none !important;
}

.sold-out {
    position: relative;
}
.sold-out:after {
    content: "SOLD OUT";
    position: absolute;
    pointer-events: none;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 70px;
    font-weight: 900;
    color: #f00;
    transform: rotate(-25deg)
}

/* Floating query image */
@media (min-width: 769px) {
.cu-float-left {
    float: left;
}
	
.cu-float-left.gb-grid-wrapper {
    width: 50%;
}

.cu-float-left.gb-grid-wrapper .gb-query-loop-item, .cu-float-left.gb-grid-wrapper .gb-query-loop-item img {
    width: 100%;
}
}
@media (min-width: 769px) {
.cu-float-right {
    float: right;
}
	
.cu-float-right.gb-grid-wrapper {
    width: 50%;
}

.cu-float-right.gb-grid-wrapper .gb-query-loop-item, .cu-float-right.gb-grid-wrapper .gb-query-loop-item img {
    width: 100%;
}
}</style></head><body class="error404 wp-embed-responsive wp-theme-generatepress wp-child-theme-GPchild21122018 post-image-below-header post-image-aligned-left infinite-scroll secondary-nav-above-header secondary-nav-aligned-right slideout-enabled slideout-mobile sticky-menu-fade sticky-enabled both-sticky-menu mobile-header mobile-header-logo mobile-header-sticky right-sidebar nav-below-header one-container nav-search-enabled header-aligned-right dropdown-click-arrow dropdown-click" itemtype="https://schema.org/WebPage" itemscope>
